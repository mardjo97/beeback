<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20250306120100-1" author="beeback">
        <createTable tableName="reminder">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="device_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="uuid" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="body" type="varchar(1024)">
                <constraints nullable="true"/>
            </column>
            <column name="scheduled_at" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="hive_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="group_record_id" type="integer">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
