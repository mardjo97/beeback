# Copy to /opt/beeback/.env.backup on the server (do not commit .env.backup).
# Used by python/run_backup.sh and cron.

# Required for backup_beeback_db.py (must match docker-compose MySQL root password)
DB_PASSWORD=dorde
DB_USER=root

# Optional: for send_beeback_db.py (email backup)
# GMAIL_PASSWORD=your-app-password
# BACKUP_RECIPIENT_EMAIL=backup.beeback@gmail.com
